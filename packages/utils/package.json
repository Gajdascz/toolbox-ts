{
  "name": "@toolbox-ts/utils",
  "version": "0.7.0",
  "private": false,
  "description": "Utils",
  "keywords": [
    "toolbox-ts",
    "typescript",
    "utilities",
    "utils"
  ],
  "homepage": "https://github.com/gajdascz/toolbox-ts/tree/main/packages/utils",
  "license": "MIT",
  "author": {
    "name": "Nolan Gajdascz",
    "email": "dev.gajdascz@gmail.com",
    "url": "https://github.com/gajdascz"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gajdascz/toolbox-ts"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/modules/index.js",
  "types": "./dist/modules/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/modules/index.d.ts",
      "import": "./dist/modules/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./Obj": {
      "types": "./dist/modules/Obj/index.d.ts",
      "import": "./dist/modules/Obj/index.js"
    },
    "./Arr": {
      "types": "./dist/modules/Arr/index.d.ts",
      "import": "./dist/modules/Arr/index.js"
    },
    "./Tuple": {
      "types": "./dist/modules/Tuple/index.d.ts",
      "import": "./dist/modules/Tuple/index.js"
    },
    "./Str": {
      "types": "./dist/modules/Str/index.d.ts",
      "import": "./dist/modules/Str/index.js"
    },
    "./Num": {
      "types": "./dist/modules/Num/index.d.ts",
      "import": "./dist/modules/Num/index.js"
    },
    "./libs/*": {
      "types": "./dist/modules/*/lib/index.d.ts",
      "import": "./dist/modules/*/lib/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@toolbox-ts/types": "workspace:^",
    "@types/node": "^25.5.0"
  },
  "devDependencies": {
    "@toolbox-ts/test-utils": "workspace:^"
  }
}
