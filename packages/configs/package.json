{
  "name": "@toolbox-ts/configs",
  "version": "0.2.0",
  "private": false,
  "description": "Configuration wrappers.",
  "keywords": [
    "commitlint",
    "configs",
    "configuration",
    "toolbox-ts",
    "utilities",
    "vitest"
  ],
  "homepage": "https://github.com/gajdascz/toolbox-ts/tree/main/packages/configs",
  "license": "MIT",
  "author": {
    "name": "Nolan Gajdascz",
    "email": "dev.gajdascz@gmail.com",
    "url": "https://github.com/gajdascz"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gajdascz/toolbox-ts.git"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "import": "./dist/runtime/index.js"
    },
    "./static": {
      "types": "./dist/static/index.d.ts",
      "import": "./dist/static/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@toolbox-ts/constants": "workspace:^",
    "@toolbox-ts/types": "workspace:^",
    "@toolbox-ts/utils": "workspace:^",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "@commitlint/types": "^19.5.0",
    "dependency-cruiser": "^16.10.4",
    "lint-staged": "^15.5.2",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.56.0",
    "vitest": "^3.2.4",
    "watskeburt": "^5.0.2"
  }
}
