{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": "src",
    "tsBuildInfoFile": "../../node_modules/.cache/md.tsbuildinfo",
    "composite": true
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    ".dev",
    "**/*.test.*",
    "**/*.test-d.*",
    "**/*.spec.*",
    "**/*.bench.*"
  ]
}
