  "description": "Constants for toolbox-ts packages",
  "keywords": [
    "toolbox-ts",
    "typescript",
    "utilities"
  ],
  "homepage": "https://github.com/gajdascz/toolbox-ts/tree/main/packages/constants",
  "license": "MIT",
  "author": {
    "name": "Nolan Gajdascz",
