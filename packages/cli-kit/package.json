{
  "name": "@toolbox-ts/cli-kit",
  "version": "0.1.5",
  "private": false,
  "description": "CLI Kit utilities and base command for oclif.",
  "keywords": [
    "cli",
    "cli-kit",
    "oclif",
    "toolbox-ts",
    "utilities"
  ],
  "homepage": "https://github.com/gajdascz/toolbox-ts/tree/main/packages/cli-kit",
  "license": "MIT",
  "author": {
    "name": "Nolan Gajdascz",
    "email": "dev.gajdascz@gmail.com",
    "url": "https://github.com/gajdascz"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/gajdascz/toolbox-ts"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./utils": {
      "types": "./dist/utils/index.d.ts",
      "import": "./dist/utils/index.js"
    },
    "./reporters": {
      "types": "./dist/reporters/index.d.ts",
      "import": "./dist/reporters/index.js"
    },
    "./BaseCommand": {
      "types": "./dist/BaseCommand/index.d.ts",
      "import": "./dist/BaseCommand/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.2",
    "@oclif/core": "^4.10.2",
    "@toolbox-ts/types": "workspace:^",
    "@toolbox-ts/utils": "workspace:^",
    "execa": "^9.6.1"
  }
}
