{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "tsBuildInfoFile": "../../node_modules/.cache/file.tsbuildinfo",
    "composite": true
  },
  "include": [
    "src/**/*",
    "../types/src/configs/pnpm/pnpm-workspace",
    "../file/conflict-handler",
  ],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.*",
    "**/*.spec.*",
    "**/*.bench.*"
  ]
}